<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tech_pattern_dark">

    <View
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="-10dp"
        android:layout_marginTop="0dp"
        android:alpha="0.65"
        android:background="@drawable/tech_pattern_circle" />

    <View
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="42dp"
        android:layout_marginTop="86dp"
        android:alpha="0.72"
        android:background="@drawable/tech_pattern_circle" />

    <View
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="42dp"
        android:layout_marginEnd="16dp"
        android:alpha="0.72"
        android:background="@drawable/tech_pattern_circle" />

    <View
        android:layout_width="66dp"
        android:layout_height="66dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="96dp"
        android:alpha="0.72"
        android:background="@drawable/tech_pattern_circle" />

    <View
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="center|start"
        android:layout_marginStart="-14dp"
        android:layout_marginTop="-18dp"
        android:alpha="0.72"
        android:background="@drawable/tech_pattern_circle" />

    <View
        android:layout_width="82dp"
        android:layout_height="82dp"
        android:layout_gravity="center|end"
        android:layout_marginEnd="-18dp"
        android:layout_marginTop="-48dp"
        android:alpha="0.72"
        android:background="@drawable/tech_pattern_circle" />

    <View
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="18dp"
        android:layout_marginBottom="38dp"
        android:alpha="0.72"
        android:background="@drawable/tech_pattern_circle" />

    <View
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="80dp"
        android:alpha="0.72"
        android:background="@drawable/tech_pattern_circle" />

    <View
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="22dp"
        android:layout_marginBottom="26dp"
        android:alpha="0.72"
        android:background="@drawable/tech_pattern_circle" />

    <View
        android:layout_width="74dp"
        android:layout_height="44dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="92dp"
        android:layout_marginTop="24dp"
        android:alpha="0.78"
        android:background="@drawable/tech_pattern_circle_dark" />

    <View
        android:layout_width="74dp"
        android:layout_height="44dp"
        android:layout_gravity="center|end"
        android:layout_marginTop="68dp"
        android:layout_marginEnd="18dp"
        android:alpha="0.78"
        android:background="@drawable/tech_pattern_circle_dark" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="34dp"
        android:paddingEnd="34dp">

        <LinearLayout
            android:layout_width="154dp"
            android:layout_height="122dp"
            android:background="@drawable/tech_logo_card"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/lgo"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:contentDescription="@string/logo_techstore"
                android:src="@drawable/logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/techstore"
                android:textColor="@color/tech_text"
                android:textSize="27sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="@string/splash_tagline"
            android:textColor="@android:color/white"
            android:textSize="25sp"
            android:textStyle="bold" />
    </LinearLayout>

</FrameLayout>
