<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/tech_auth_background"
    android:orientation="vertical">

    <TextView
        android:id="@+id/txtVolver"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="22dp"
        android:layout_marginTop="24dp"
        android:text="←"
        android:textColor="@android:color/white"
        android:textSize="34sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="104dp"
        android:layout_height="104dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="26dp"
        android:background="@drawable/tech_logo_card"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:contentDescription="Logo TechStore"
            android:src="@drawable/logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TechStore"
            android:textColor="@color/tech_text"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="54dp"
        android:layout_weight="1"
        android:background="@drawable/tech_auth_panel"
        android:orientation="vertical"
        android:paddingStart="48dp"
        android:paddingTop="38dp"
        android:paddingEnd="48dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Iniciar\nSesión"
            android:textColor="@color/tech_text"
            android:textSize="40sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:letterSpacing="0.16"
            android:text="CORREO ELECTRONICO"
            android:textColor="@color/tech_muted"
            android:textSize="11sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editTextContrasena"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/tech_input"
            android:hint="correo@techstore.com"
            android:inputType="textEmailAddress"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textColor="@color/tech_text"
            android:textColorHint="@color/tech_muted" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:letterSpacing="0.16"
            android:text="CONTRASEÑA"
            android:textColor="@color/tech_muted"
            android:textSize="11sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editTextConfirmarContrasena"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/tech_input"
            android:hint="******"
            android:inputType="textPassword"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textColor="@color/tech_text"
            android:textColorHint="@color/tech_muted" />

        <Button
            android:id="@+id/btnRegistrar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/tech_button_primary"
            android:text="Iniciar Sesión"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtRecuperarPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Olvidaste contraseña?"
            android:textColor="@color/tech_muted"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnBiometria"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/tech_search_box"
            android:text="Ingresar con biometria"
            android:textAllCaps="false"
            android:textColor="@color/tech_navy"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnGoogleLogin"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/tech_search_box"
            android:text="Ingresar con Google"
            android:textAllCaps="false"
            android:textColor="@color/tech_navy"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
