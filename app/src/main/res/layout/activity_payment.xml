<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tech_light"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarPagos"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:background="@drawable/tech_top_bar"
        app:navigationIcon="@android:drawable/ic_media_previous"
        app:navigationIconTint="@android:color/white"
        app:title="@string/menu_payments"
        app:titleCentered="true"
        app:titleTextColor="@android:color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/tech_card_metric"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/payment_methods"
                    android:textColor="@color/tech_text"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/payment_subtitle"
                    android:textColor="@color/tech_muted"
                    android:textSize="14sp" />

                <RadioGroup
                    android:id="@+id/radioGroupPagos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/radioTarjeta"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:buttonTint="@color/tech_blue"
                        android:checked="true"
                        android:text="@string/credit_debit_card"
                        android:textColor="@color/tech_text"
                        android:textSize="15sp" />

                    <RadioButton
                        android:id="@+id/radioPse"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:buttonTint="@color/tech_blue"
                        android:text="@string/payment_pse"
                        android:textColor="@color/tech_text"
                        android:textSize="15sp" />

                    <RadioButton
                        android:id="@+id/radioNequi"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:buttonTint="@color/tech_blue"
                        android:text="@string/payment_nequi"
                        android:textColor="@color/tech_text"
                        android:textSize="15sp" />

                    <RadioButton
                        android:id="@+id/radioDaviplata"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:buttonTint="@color/tech_blue"
                        android:text="@string/payment_daviplata"
                        android:textColor="@color/tech_text"
                        android:textSize="15sp" />
                </RadioGroup>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/tech_card_metric"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/cart_summary"
                    android:textColor="@color/tech_text"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPagoProductos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/tech_text"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvPagoSubtotal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/tech_text"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvPagoEnvio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/tech_text"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvPagoTotal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/tech_dashboard_text"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Button
                android:id="@+id/btnPagarAhora"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/tech_button_primary"
                android:text="@string/pay_now"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnVolverPagos"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/tech_search_box"
                android:text="@string/back"
                android:textAllCaps="false"
                android:textColor="@color/tech_navy"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
