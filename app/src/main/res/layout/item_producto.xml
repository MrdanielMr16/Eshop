<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white"
    android:orientation="horizontal"
    android:padding="12dp">

    <ImageView
        android:id="@+id/imgProducto"
        android:layout_width="78dp"
        android:layout_height="78dp"
        android:background="@drawable/tech_search_box"
        android:contentDescription="@string/image_product"
        android:padding="8dp"
        android:scaleType="centerCrop"
        android:src="@drawable/logo" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNombreProducto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/product_default_name"
            android:textColor="@color/tech_text"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPrecioProducto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/product_default_price"
            android:textColor="@color/tech_text"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvStockProducto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/product_default_stock"
            android:textColor="@color/tech_muted"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvDescripcionProducto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/product_default_description"
            android:textColor="@color/tech_muted"
            android:textSize="12sp" />

        <LinearLayout
            android:id="@+id/layoutAccionesProducto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:visibility="gone">

            <Button
                android:id="@+id/btnEditarProductoItem"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/tech_button_primary"
                android:text="@string/edit_product"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnEliminarProductoItem"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/tech_button_danger"
                android:text="@string/delete_product"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
